WEGOCOMPLY_MODE=mock
AUTH_MODE=mock
BACKEND_CORS_ORIGINS=http://localhost:5173
BACKEND_CORS_ALLOWED_METHODS=GET,POST,OPTIONS
BACKEND_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID,X-Mock-User,X-Mock-Email,X-Mock-Name,X-Mock-Roles
BACKEND_CORS_ALLOW_CREDENTIALS=true
AML_MODEL_PATH=../ml/aml_model.pkl
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
REDIS_URL=redis://localhost:6379/0
AUDIT_LOG_PATH=./audit/audit.log.jsonl
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
MOCK_AUTH_USER_ID=demo-admin
MOCK_AUTH_EMAIL=admin@wegocomply.local
MOCK_AUTH_NAME=Demo Admin
MOCK_AUTH_ROLES=admin
AZURE_AD_B2C_CLIENT_ID=your_api_application_id
AZURE_AD_B2C_METADATA_URL=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/your-policy/v2.0/.well-known/openid-configuration
AZURE_AD_B2C_ISSUER=
AZURE_AD_B2C_JWKS_URL=

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_key
AZURE_OPENAI_KEY_SECRET_NAME=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your_key
AZURE_DOCUMENT_INTELLIGENCE_KEY_SECRET_NAME=

AZURE_FACE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_FACE_KEY=your_key
AZURE_FACE_KEY_SECRET_NAME=

DOJAH_APP_ID=your_dojah_app_id
DOJAH_APP_ID_SECRET_NAME=
DOJAH_API_KEY=your_dojah_api_key
DOJAH_API_KEY_SECRET_NAME=
DOJAH_BASE_URL=https://api.dojah.io
DOJAH_SANDBOX_BASE_URL=https://sandbox.dojah.io

VERIFYME_SECRET_KEY=your_verifyme_secret_key

# Identity Provider Configuration
IDENTITY_MODE=mock
IDENTITY_PROVIDER=nimc_mock

# VerifyMe Configuration
VERIFYME_SECRET_KEY=your_verifyme_secret_key_here
VERIFYME_BASE_URL=https://vapi.verifyme.ng/v1/verifications/identities

# NIMC Configuration (placeholder for future implementation)
NIMC_USERNAME=your_nimc_username
NIMC_PASSWORD=your_nimc_password
NIMC_ORGID=your_nimc_orgid
NIMC_BASE_URL=https://api.nimc.gov.ng
NIMC_VPN_REQUIRED=true

# NIMC Mock Configuration (for development/testing)
NIMC_MOCK_USERNAME=demo_user
NIMC_MOCK_PASSWORD=demo_pass
NIMC_MOCK_ORGID=demo_org
NIMC_MOCK_TOKEN_EXPIRY_MINUTES=30

DATABASE_URL=postgresql://user:password@localhost:5432/wegocomply
