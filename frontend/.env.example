# Frontend Environment Variables
VITE_AUTH_MODE=mock
VITE_API_BASE_URL=http://localhost:8000

# Mock Authentication (for development)
VITE_MOCK_AUTH_USER_ID=demo-admin
VITE_MOCK_AUTH_EMAIL=admin@wegocomply.local
VITE_MOCK_AUTH_NAME=Demo Admin
VITE_MOCK_AUTH_ROLES=admin

# Azure AD B2C (for production)
VITE_AZURE_AD_B2C_CLIENT_ID=your_api_application_id
VITE_AZURE_AD_B2C_AUTHORITY=https://your-tenant.b2clogin.com/your-tenant.onmicrosoft.com/B2C_1_signupsignin
VITE_AZURE_AD_B2C_KNOWN_AUTHORITIES=https://your-tenant.b2clogin.com
VITE_AZURE_AD_B2C_SCOPES=openid,profile,offline_access
VITE_AZURE_AD_B2C_REDIRECT_URI=http://localhost:5173
VITE_AZURE_AD_B2C_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
