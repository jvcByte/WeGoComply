VITE_AUTH_MODE=mock
VITE_API_BASE_URL=
VITE_MOCK_AUTH_USER_ID=demo-admin
VITE_MOCK_AUTH_EMAIL=admin@wegocomply.local
VITE_MOCK_AUTH_NAME=Demo Admin
VITE_MOCK_AUTH_ROLES=admin

# -----------------------------------------------------------------------
# Microsoft Entra ID (formerly Azure AD)
# Set VITE_AUTH_MODE=entra_id to enable.
# Register a Single-Page Application at: https://portal.azure.com
#   → Entra ID → App registrations → New registration
#   → Platform: Single-page application (SPA)
#   → Redirect URI: http://localhost:5173
# -----------------------------------------------------------------------
VITE_ENTRA_CLIENT_ID=your_spa_application_id
VITE_ENTRA_TENANT_ID=your_tenant_id
VITE_ENTRA_SCOPES=api://your_api_application_id/.default
VITE_ENTRA_REDIRECT_URI=http://localhost:5173
VITE_ENTRA_POST_LOGOUT_REDIRECT_URI=http://localhost:5173
